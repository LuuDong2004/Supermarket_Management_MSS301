# ---------------------------------------------------------------------------
# Shared environment for docker-compose. Override before any real deployment.
# ---------------------------------------------------------------------------

# PostgreSQL
POSTGRES_USER=supermarket
POSTGRES_PASSWORD=supermarket

# Service ports (host side)
GATEWAY_PORT=8080
AUTH_PORT=8081
USER_PORT=8082
DISCOVERY_PORT=8761

# JWT — MUST be identical for auth-service and api-gateway. Min 32 bytes.
JWT_SECRET=Zm9yLWRldi1vbmx5LXN1cGVyLW1hcmtldC1tc3MzMDEtY2hhbmdlLW1lLXBsZWFzZS0xMjM0NTY3ODkw
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Shared key for service-to-service (auth -> user) internal calls
INTERNAL_API_KEY=internal-dev-key-change-me

# CORS
CORS_ALLOWED_ORIGINS=*
