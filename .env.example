# ---------------------------------------------------------------------------
# Template for the shared docker-compose environment. Copy to .env and fill in.
# Every value below is REQUIRED — services fail to start if a secret is unset.
# ---------------------------------------------------------------------------

# MySQL 8 — single engine backing every service (DB-per-service on one instance)
MYSQL_ROOT_PASSWORD=
MYSQL_USER=supermarket
MYSQL_PASSWORD=

# MinIO object storage (image uploads)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=sms-media

# Service ports. Only GATEWAY_PORT is published publicly; the rest bind to
# 127.0.0.1 so they cannot be reached bypassing gateway authentication.
GATEWAY_PORT=8080
AUTH_PORT=8081
USER_PORT=8082
PRODUCT_PORT=8083
INVENTORY_PORT=8084
SALES_PORT=8085
REPORTING_PORT=8086
SUPPLIER_PORT=8087
NOTIFICATION_PORT=8088
DISCOVERY_PORT=8761

# JWT — MUST be identical for auth-service and api-gateway. Min 32 bytes.
# Generate: openssl rand -base64 48
JWT_SECRET=
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Shared key for service-to-service internal calls (X-Internal-Api-Key).
# Generate: openssl rand -base64 32
INTERNAL_API_KEY=

# SePay webhook authentication token. Generate: openssl rand -base64 32
SEPAY_WEBHOOK_TOKEN=

# CORS — explicit frontend origin(s), comma separated. Never "*".
CORS_ALLOWED_ORIGINS=http://localhost:5173
